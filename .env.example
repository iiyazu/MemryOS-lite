# --- MemoryOS core (maps to pydantic Settings fields) ---
DATA_DIR=.memoryos
DATABASE_URL=
MODEL_MAX_CONTEXT=128000
ROT_SAFE_BUDGET=2400
HARD_LIMIT=8000
RECENT_MESSAGE_LIMIT=8
MEMORYOS_EVIDENCE_RESERVE_RATIO=0.6
MEMORYOS_EVIDENCE_RESERVE_TOKENS=64
MEMORYOS_EVIDENCE_RESERVE_MIN_PAGES=8
MEMORYOS_PAGING_MODE=heuristic

# --- OpenAI / compatible LLM (optional for deterministic eval / demo) ---
MEMORYOS_LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=
MEMORYOS_MODEL=gpt-4o-mini
MEMORYOS_EMBEDDING_MODEL=text-embedding-3-small

# --- DeepSeek chat LLM (optional; OpenAI-compatible chat endpoint) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Postgres (used by docker-compose; app will switch to it in M2) ---
POSTGRES_DB=memoryos
POSTGRES_USER=memoryos
POSTGRES_PASSWORD=change-me-in-production

# --- API auth (used in M5) ---
API_KEY=dev-local-key
