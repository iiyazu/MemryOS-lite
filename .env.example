# --- MemoryOS core (maps to pydantic Settings fields) ---
DATA_DIR=.memoryos
MODEL_MAX_CONTEXT=128000
ROT_SAFE_BUDGET=2400
HARD_LIMIT=8000
RECENT_MESSAGE_LIMIT=8
MEMORYOS_EVIDENCE_RESERVE_RATIO=0.6
MEMORYOS_EVIDENCE_RESERVE_TOKENS=64
MEMORYOS_EVIDENCE_RESERVE_MIN_PAGES=8
MEMORYOS_PAGING_MODE=heuristic

# --- OpenAI / compatible APIs (optional; leave blank for offline defaults) ---
# Deterministic commands such as `memoryos demo agent`, `memoryos eval run`,
# and public evals with `--no-llm-answer --no-llm-judge` do not require these.
# Real API calls may occur when keys are set and you opt into LLM paging,
# LLM judge/answer flags, rewrite/rerank, agent graphs without a fake LLM, or
# embedding indexing/search.
MEMORYOS_LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=
MEMORYOS_MODEL=gpt-4o-mini
MEMORYOS_EMBEDDING_MODEL=text-embedding-3-small

# --- DeepSeek chat LLM (optional; OpenAI-compatible chat endpoint) ---
# DeepSeek is used only for chat-compatible features. Embeddings still use
# OPENAI_API_KEY and MEMORYOS_EMBEDDING_MODEL.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# --- API auth ---
API_KEY=dev-local-key

# --- Qdrant vector store (optional; falls back to SQLite cosine if unset) ---
QDRANT_URL=
QDRANT_COLLECTION=memoryos_pages
