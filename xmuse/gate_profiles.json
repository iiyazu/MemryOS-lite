{
  "schema_version": 1,
  "defaults": {
    "full_gate_profile": "strict-product",
    "full_gate_interval": 20,
    "unknown_diff_policy": "strict-product",
    "unclassified_test_policy": "fail"
  },
  "command_catalog": {
    "pytest": {
      "argv": [
        "uv",
        "run",
        "pytest"
      ],
      "cwd": ".",
      "timeout_s": 0,
      "allow_extra_args": true
    },
    "ruff-src": {
      "argv": [
        "uv",
        "run",
        "ruff",
        "check",
        "src/"
      ],
      "cwd": ".",
      "timeout_s": 0,
      "allow_extra_args": false
    },
    "ruff-xmuse": {
      "argv": [
        "uv",
        "run",
        "ruff",
        "check",
        "xmuse/"
      ],
      "cwd": ".",
      "timeout_s": 0,
      "allow_extra_args": false
    },
    "mypy-src": {
      "argv": [
        "uv",
        "run",
        "mypy",
        "--ignore-missing-imports"
      ],
      "cwd": ".",
      "timeout_s": 60,
      "allow_extra_args": true
    }
  },
