{
  "name": "God-Plan-Execute-Review State Machine",
  "version": "1.0",
  "states": {
    "GOD_DISPATCH": {
      "actor": "god",
      "description": "God 读蓝图，生成当前 phase 的 dispatch",
      "next_on_success": "PLAN_STORM",
      "outputs": [
        "god_dispatch.json"
      ],
      "superpowers": [
        "writing-plans",
        "kanban-orchestrator"
      ]
    },
    "PLAN_STORM": {
      "actor": "plan_agent",
      "description": "Plan agent 启动 brainstorming subagent",
      "next_on_success": "PLAN_DRAFT",
      "outputs": [
        "brainstorm.md"
      ],
      "superpowers": [
        "writing-plans"
      ]
    },
    "PLAN_DRAFT": {
      "actor": "plan_agent",
      "description": "根据 brainstorming 结果写 spec + plan",
      "next_on_success": "PLAN_SELF_REVIEW",
      "outputs": [
        "spec.md",
        "plan.md"
      ],
      "superpowers": [
        "writing-plans"
      ]
    },
    "PLAN_SELF_REVIEW": {
      "actor": "plan_agent",
      "description": "启动 subagent 审查 spec + plan，迭代定稿",
      "next_on_success": "EXECUTE",
      "next_on_fail": "PLAN_DRAFT",
      "max_retries": 3,
      "outputs": [
        "plan_review.md",
        "plan_final.md"
      ],
      "superpowers": [
        "requesting-code-review",
        "writing-plans"
      ]
    },
    "EXECUTE": {
      "actor": "execute_agent",
      "description": "subagent-driven 按 plan 执行",
      "next_on_success": "EXECUTE_SELF_REVIEW",
      "outputs": [
        "result.md"
      ],
      "superpowers": [
        "subagent-driven-development",
        "test-driven-development",
        "systematic-debugging"
      ]
    },
    "EXECUTE_SELF_REVIEW": {
      "actor": "execute_agent",
      "description": "内审 subagent 审查代码质量",
      "next_on_success": "REVIEW",
      "next_on_fail": "EXECUTE",
      "max_retries": 2,
      "outputs": [
        "execute_review.md"
      ],
      "superpowers": [
        "requesting-code-review"
      ]
    },
    "REVIEW": {
      "actor": "review_agent",
      "description": "对照 God 指标判断 PASS/FAIL",
      "next_on_pass": "ACK",
      "next_on_fail": "EXECUTE",
      "next_on_escalate": "GOD_ADJUST",
      "max_fail_to_execute": 3,
      "outputs": [
        "review_verdict.json",
        "ack.json",
        "escalate.json"
      ],
      "superpowers": [
        "requesting-code-review",
        "evaluating-llms-harness"
      ]
    },
    "ACK": {
      "actor": "review_agent",
      "description": "发送 ACK 给 God",
      "next_on_success": "GOD_ADVANCE",
      "outputs": [
        "ack.json"
      ],
      "superpowers": []
    },
    "GOD_ADVANCE": {
      "actor": "god",
      "description": "ACK 后: git commit 存档 → 反思 subagent → 可能调整蓝图 → 推进下一 phase",
      "next_on_success": "GOD_DISPATCH",
      "next_on_terminate": "DONE",
      "steps": [
        "git add -A && git commit -m '[phase-id] ACK: ...'",
        "spawn reflection subagent → reflect_{phase-id}.md",
        "read reflect → decide if blueprint needs adjustment",
        "if adjust → update blueprint.md + state.json phases",
        "mark phase completed → advance"
      ],
      "outputs": [
        "git commit",
        "reflect_{phase-id}.md",
        "blueprint.md update",
        "state.json update"
      ],
      "superpowers": [
        "writing-plans",
        "kanban-orchestrator",
        "brainstorming"
      ]
    },
    "GOD_ADJUST": {
      "actor": "god",
      "description": "收到 escalate.json: 启动分析 subagent → 读分析结果 → 决策(拆分/放宽/重设/放弃) → 更新蓝图 → 重新 dispatch",
      "next_on_success": "GOD_DISPATCH",
      "steps": [
        "spawn analysis subagent → escalate_analysis_{phase-id}.md",
        "read analysis → decide: split / relax / redesign / abandon",
        "update blueprint.md with adjustment record",
        "reset affected phase(s), re-dispatch"
      ],
      "outputs": [
        "escalate_analysis_{phase-id}.md",
        "blueprint.md update",
        "state.json update"
      ],
      "superpowers": [
        "writing-plans",
        "kanban-orchestrator",
        "brainstorming"
      ]
    },
    "DONE": {
      "actor": "terminal",
      "description": "所有 phase 完成，终止",
      "next_on_success": null,
      "outputs": [
        "final_report.md"
      ]
    }
  },
  "communication_contracts": {
    "god_dispatch.json": {
      "producer": "god",
      "consumers": [
        "plan_agent",
        "review_agent"
      ],
      "schema": {
        "phase": "string",
        "phase_index": "int",
        "phase_name": "string",
        "target_state": "string",
        "task_description": "string — God 的蓝图描述",
        "for_plan_agent": {
          "goal": "string",
          "constraints": [
            "string"
          ],
          "relevant_files": [
            "string"
          ],
          "design_notes": "string"
        },
        "for_review_agent": {
          "tests_must_pass": "bool",
          "regression_bar": "string",
          "spec_checklist": [
            "string"
          ],
          "benchmark_commands": [
            "string"
          ],
          "benchmark_pass_threshold": "string"
        }
      }
    },
    "brainstorm.md": {
      "producer": "plan_agent (via brainstorming subagent)",
      "consumers": [
        "plan_agent"
      ],
      "schema": "自然语言文档：多方案对比 + 推荐方案 + 风险"
    },
    "plan_final.md": {
      "producer": "plan_agent",
      "consumers": [
        "execute_agent"
      ],
      "schema": "writing-plans 格式：bite-sized tasks + 精确文件路径 + TDD 步骤"
    },
    "result.md": {
      "producer": "execute_agent",
      "consumers": [
        "review_agent"
      ],
      "schema": "修改文件列表 + 测试结果 + 问题记录"
    },
    "review_verdict.json": {
      "producer": "review_agent",
      "consumers": [
        "execute_agent"
      ],
      "schema": {
        "verdict": "PASS | FAIL | ESCALATE",
        "checks": {
          "spec_compliance": {
            "passed": "bool",
            "issues": [
              "string"
            ]
          },
          "tests": {
            "passed": "bool",
            "failed_count": "int"
          },
          "regression": {
            "passed": "bool",
            "details": "string"
          },
          "security": {
            "passed": "bool",
            "issues": [
              "string"
            ]
          },
          "benchmark": {
            "passed": "bool",
            "scores": "dict"
          }
        },
        "fix_guide": "string",
        "iter_count": "int"
      }
    },
    "ack.json": {
      "producer": "review_agent",
      "consumers": [
        "god"
      ],
      "schema": {
        "verdict": "ACK",
        "phase": "string",
        "phase_name": "string",
        "target_state": "string",
        "evidence": {
          "tests_passed": "int",
          "checks_passed": "int"
        }
      }
    },
    "escalate.json": {
      "producer": "review_agent",
      "consumers": [
        "god"
      ],
      "schema": {
        "verdict": "ESCALATE",
        "phase": "string",
        "phase_name": "string",
        "target_state": "string",
        "iter_count": "int",
        "history": [
          "review_verdict.json..."
        ],
        "recommendation": "string"
      }
    },
    "reflect_{phase-id}.md": {
      "producer": "god (via reflection subagent)",
      "consumers": [
        "god"
      ],
      "schema": "反思报告: 成功确认 + 发现与信号 + 蓝图调整建议 + 是否需要调整"
    },
    "escalate_analysis_{phase-id}.md": {
      "producer": "god (via analysis subagent)",
      "consumers": [
        "god"
      ],
      "schema": "升级分析: 根因 + 替代方案 + 建议 (拆分/放宽/重设/放弃)"
    },
    "git commit": {
      "producer": "god",
      "consumers": [
        "human",
        "git history"
      ],
      "schema": "[phase-id] ACK: {name} — tests {N} passed, {M} checks"
    },
    "spec.md": {
      "producer": "plan_agent",
      "consumers": [
        "plan_agent"
      ],
      "schema": "设计文档: what + why + 接口定义"
    },
    "plan.md": {
      "producer": "plan_agent",
      "consumers": [
        "plan_agent"
      ],
      "schema": "实现步骤: how + exact code + TDD 测试 (self-review 前)"
    },
    "execute_review.md": {
      "producer": "execute_agent (via review subagent)",
      "consumers": [
        "review_agent"
      ],
      "schema": "Execute 内审报告: 小问题已修复 + 大问题标记"
    }
  }
}