+
+class ArchivalDocument(BaseModel):
+    id: str
+    archive_id: str | None = None
+    title: str
+    text: str
+    version: int = 1
+    tags: list[str] = Field(default_factory=list)
+    source_refs: list[SourceRef] = Field(default_factory=list)
