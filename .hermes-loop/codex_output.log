    "fall",
    "autumn",
    "winter",
)
_TEMPORAL_BODY_RE = re.compile(
    r"\b(?:" + "|".join(_TEMPORAL_MONTH_NAMES) + r")\s+\d{1,2}(?:st|nd|rd|th)?\b"
    r"|\b\d{4}[/-]\d{1,2}[/-]\d{1,2}\b"
