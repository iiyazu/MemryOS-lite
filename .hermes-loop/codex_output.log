+    diagnostics: list[DiagnosticEvent] = Field(default_factory=list)
+    metadata: dict[str, Any] = Field(default_factory=dict)
+
+
+class ContextComposer(Protocol):
+    def build(self, request: ContextComposerRequest) -> ContextPackageV3: ...
