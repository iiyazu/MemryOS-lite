+        reason_code="budget_limit",
+    )
+
+    assert history.source_refs == [ref]
+    assert diagnostic.layer == "recall"
+    assert decision.dropped_item_ids == ["passage_2"]
+
+    with pytest.raises(ValidationError):
+        MemoryHistoryEvent(
+            memory_id="mem_2",
+            memory_type="archival_memory",
+            operation="replace",
+            actor="agent",
+            reason="bad replace",
+            after={"value": "new"},
+            source_refs=[ref],
+        )
+```
