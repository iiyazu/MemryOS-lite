+    "V3_NO_NEW_TARGETS",
+    "ensure_persisted_identity_scope",
+    "episode_to_recall_entry",
+    "item_to_archival_memory",
+    "item_to_archival_passage",
+    "message_to_log_entry",
+    "page_to_archival_document",
+]
